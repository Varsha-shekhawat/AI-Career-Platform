generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ResumeAnalysis {
  id               String   @id @default(cuid())
  userId           String
  fileName         String
  candidateName    String
  atsScore         Int
  scoreExplanation String   @db.Text
  strengths        String   @db.Text // JSON-encoded array
  weaknesses       String   @db.Text // JSON-encoded array
  recommendations  String   @db.Text // JSON-encoded array
  createdAt        DateTime @default(now())

  @@index([userId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  createdAt    DateTime @default(now())
}
